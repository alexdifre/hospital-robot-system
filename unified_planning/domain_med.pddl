           (+ (* (w2 ?r) (battery-deliver_on_bedside_table))
              (* (w4 ?r) (approach-feature bedside_table_right)))))
    )
  )


  (:action recharge
    :parameters (?r - robot ?l - location)
    :precondition (and
      (at ?r ?l)
      (charger-location ?l)
      (not (delivered ?r))
      (not (medicine-recollect-required ?r))
      (not (supplement-recollect-required ?r))
    )
    :effect (and
      (increase (total_time) (duration-recharge))
      (increase (discrete_steps) 1)
      (increase (stage_cost)
        (+ (* (w0 ?r) (duration-recharge))))
      (assign (battery-soc ?r) 1.0)
    )
  )

