  (:action approach_to_left_side
    :parameters (?r - robot ?m - meal ?from - location ?to - location)
    :precondition (and
      (at ?r ?from)
      (meal_to_prepare ?m)
      (patient-location ?to)
      (patient-left-location ?to)
      (not (= ?from ?to))
      (>= (- (battery-soc ?r) (nav-battery ?from ?to))
          (+ (battery-deliver_on_bedside_table) (nearest-charger-battery ?to)))
      (or (meal_cooked ?r) (not (requires_cooking ?m)))
      (meal_palatable ?r)
      (meal_assembled ?r)
      (not (delivered ?r))
    )
    :effect (and
      (increase (total_time) (nav-time ?from ?to))
      (increase (discrete_steps) 1)
      (not (at ?r ?from))
      (at ?r ?to)
      (can_be_deliverable ?r)
      (decrease (battery-soc ?r) (nav-battery ?from ?to))
      (increase (stage_cost)
        (+ (* (w0 ?r) (nav-time ?from ?to))
           (+ (* (w1 ?r) (location-safety ?to))
              (+ (* (w2 ?r) (nav-battery ?from ?to))
                 (+ (* (w3 ?r) (proximity-feature ?to))
                    (* (w4 ?r) (approach-feature ?to)))))))
      (when (< (- (battery-soc ?r) (nav-battery ?from ?to)) 0.15)
        (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (nav-battery ?from ?to)) 0.25)
