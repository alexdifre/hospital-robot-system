(define (domain medication_delivery)
  (:requirements :strips :typing :equality :negative-preconditions :action-costs :numeric-fluents :conditional-effects)

  (:types
    robot medicine supplement approach_target - object
    location delivery_target - approach_target
  )

  (:constants
    med_antibiotic med_analgesic med_insulin - medicine
    supp_vitamin_d supp_electrolyte supp_omega3 - supplement
    bedside_table_left bedside_table_right - delivery_target
  )

  (:predicates
    (at ?r - robot ?l - location)

    (pharmacy-location ?l - location)
    (pharmacy-north-location ?l - location)
    (pharmacy-south-location ?l - location)
    (supply-location ?l - location)
    (supply-a-location ?l - location)
    (supply-b-location ?l - location)
    (charger-location ?l - location)
    (main-charger ?l - location)
    (backup-charger ?l - location)
    (patient-location ?l - location)
    (patient-left-location ?l - location)
    (patient-right-location ?l - location)

    (requested-medicine ?m - medicine)
    (requested-supplement ?s - supplement)

    (has-medication ?r - robot)
    (has-supplement ?r - robot)
    (carrying-medicine ?r - robot ?m - medicine)
    (carrying-supplement ?r - robot ?s - supplement)
    (unchecked-medication ?r - robot)
    (unchecked-supplement ?r - robot)
    (correct-medication ?r - robot)
    (correct-supplement ?r - robot)
    (medicine-recollect-required ?r - robot)
    (supplement-recollect-required ?r - robot)
    (can_be_deliverable ?r - robot)
    (delivered ?r - robot)

  )

  (:functions
    (stage_cost)
    (total_time)
    (discrete_steps)
    (loc-x ?l - location)
    (loc-y ?l - location)
    ; Action durations. These are zero-arity numeric fluents so the replanner can update them.

    (duration-collect-medication)
    (duration-collect-supplement)
    (duration-check-medication)
    (duration-check-supplement)
    (duration-recharge)
    (duration-put_down)

    ; Battery used by in-place actions. Movement battery is represented by nav-battery.
    (battery-collect-medication)
    (battery-collect-supplement)
    (battery-check-medication)
    (battery-check-supplement)
    (battery-put_down)
    (battery-deliver_on_bedside_table)

    ; w0..w4 are replanner-owned preference weights for stage_cost.
    ; The domain uses them in the scalar product but never modifies them.
    (battery-soc ?r - robot)
    (w0 ?r - robot)
    (w1 ?r - robot)
    (w2 ?r - robot)
    (w3 ?r - robot)
    (w4 ?r - robot)

    ; Feature deltas follow calculate_action_cost_Medication_flattened and are NOT scaled.
    (nav-time ?from ?to - location)
    (nav-battery ?from ?to - location)
    (nearest-charger-battery ?l - location)
    (location-safety ?l - location)
    (approach-feature ?x - approach_target)
    (proximity-feature ?l - location)
    (deliver-time)
  )

  (:action go_to_pharmacy_north
    :parameters (?r - robot ?from - location ?to - location)
    :precondition (and
      (at ?r ?from)
      (pharmacy-location ?to)
      (pharmacy-north-location ?to)
      (not (= ?from ?to))
      (>= (- (battery-soc ?r) (nav-battery ?from ?to)) (nearest-charger-battery ?to))
      (not (unchecked-medication ?r))
      (not (unchecked-supplement ?r))
      (not (medicine-recollect-required ?r))
      (not (supplement-recollect-required ?r))
      (not (delivered ?r))
    )
    :effect (and
      (increase (total_time) (nav-time ?from ?to))
      (increase (discrete_steps) 1)
      (not (at ?r ?from))
      (at ?r ?to)
      (decrease (battery-soc ?r) (nav-battery ?from ?to))
      (increase (stage_cost)
        (+ (* (w0 ?r) (nav-time ?from ?to))
           (+ (* (w1 ?r) (location-safety ?to))
              (+ (* (w2 ?r) (nav-battery ?from ?to))
                 (+ (* (w3 ?r) (proximity-feature ?to))
                    (* (w4 ?r) (approach-feature ?to)))))))
      (when (< (- (battery-soc ?r) (nav-battery ?from ?to)) 0.15)
        (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (nav-battery ?from ?to)) 0.25)
        (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

