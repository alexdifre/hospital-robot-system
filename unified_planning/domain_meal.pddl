           (+ (* (w1 ?r) (location-safety ?to))
              (+ (* (w2 ?r) (nav-battery ?from ?to))
                 (+ (* (w3 ?r) (proximity-feature ?to))
                    (* (w4 ?r) (approach-feature ?to)))))))
      (when (< (- (battery-soc ?r) (nav-battery ?from ?to)) 0.15)
        (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (nav-battery ?from ?to)) 0.25)
        (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action collect_ingredient
    :parameters (?r - robot ?m - meal ?i - ingredient ?l - location)
    :precondition (and
      (at ?r ?l)
      (meal_to_prepare ?m)
      (required_ingredient ?m ?i)
      (ingredient_available ?l ?i)
      (not (collected_ingredient ?r ?i))
      (> (battery-soc ?r) (+ (battery-collect_ingredient) (nearest-charger-battery ?l)))
    )
    :effect (and
      (collected_ingredient ?r ?i)
      (not (missing_ingredient ?r ?i))
      (increase (total_time) (collect_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-collect_ingredient))
      (increase (stage_cost) (+ (* (w0 ?r) (collect_duration)) (* (w2 ?r) (battery-collect_ingredient))))
      (when (< (- (battery-soc ?r) (battery-collect_ingredient)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-collect_ingredient)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action check_ingredients
    :parameters (?r - robot ?m - meal ?l - location)
    :precondition (and
      (at ?r ?l)
      (meal_to_prepare ?m)
      (not (ingredients_checked ?r))
      (forall (?i - ingredient) (or (not (required_ingredient ?m ?i)) (collected_ingredient ?r ?i)))
      (forall (?i - ingredient) (or (not (required_ingredient ?m ?i)) (not (missing_ingredient ?r ?i))))
      (forall (?i - ingredient) (or (not (required_ingredient ?m ?i)) (not (wrong_ingredient ?r ?i))))
      (forall (?i - ingredient) (or (not (required_ingredient ?m ?i)) (not (expired_ingredient ?r ?i))))
      (forall (?i - ingredient) (or (not (required_ingredient ?m ?i)) (not (allergen_present ?r ?i))))
      (> (battery-soc ?r) (+ (battery-check_ingredients) (nearest-charger-battery ?l)))
    )
    :effect (and
      (ingredients_checked ?r)
      (ingredients_safe ?r ?m)
      (increase (total_time) (check_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-check_ingredients))
      (increase (stage_cost) (+ (* (w0 ?r) (check_duration)) (* (w2 ?r) (battery-check_ingredients))))
      (when (< (- (battery-soc ?r) (battery-check_ingredients)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-check_ingredients)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action sanitize_workspace
    :parameters (?r - robot ?l - location)
    :precondition (and
      (at ?r ?l)
      (or (prep-station-location ?l) (cooking-station ?l))
      (not (workspace-clean ?r))
      (> (battery-soc ?r) (+ (battery-sanitize_workspace) (nearest-charger-battery ?l)))
    )
    :effect (and
      (workspace-clean ?r)
      (robot-hands-clean ?r)
      (not (cross-contamination-risk ?r))
      (increase (total_time) (sanitize_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-sanitize_workspace))
      (increase (stage_cost) (+ (* (w0 ?r) (sanitize_duration)) (* (w2 ?r) (battery-sanitize_workspace))))
      (when (< (- (battery-soc ?r) (battery-sanitize_workspace)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-sanitize_workspace)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action wash_ingredients
    :parameters (?r - robot ?m - meal ?l - location)
    :precondition (and
      (at ?r ?l)
      (prep-station-location ?l)
      (meal_to_prepare ?m)
      (ingredients_safe ?r ?m)
      (workspace-clean ?r)
      (robot-hands-clean ?r)
      (not (ingredients_washed ?r))
      (> (battery-soc ?r) (+ (battery-wash_ingredients) (nearest-charger-battery ?l)))
    )
    :effect (and
      (ingredients_washed ?r)
      (increase (total_time) (wash_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-wash_ingredients))
      (increase (stage_cost) (+ (* (w0 ?r) (wash_duration)) (* (w2 ?r) (battery-wash_ingredients))))
      (when (< (- (battery-soc ?r) (battery-wash_ingredients)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-wash_ingredients)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action chop_ingredients
    :parameters (?r - robot ?m - meal ?l - location)
    :precondition (and
      (at ?r ?l)
      (prep-station-location ?l)
      (meal_to_prepare ?m)
      (ingredients_safe ?r ?m)
      (ingredients_washed ?r)
      (workspace-clean ?r)
      (robot-hands-clean ?r)
      (not (cross-contamination-risk ?r))
      (not (ingredients_chopped ?r))
      (> (battery-soc ?r) (+ (battery-chop_ingredients) (nearest-charger-battery ?l)))
    )
    :effect (and
      (ingredients_chopped ?r)
      (when (cold_meal ?m) (ready_for_quality ?r))
      (increase (total_time) (chop_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-chop_ingredients))
      (increase (stage_cost) (+ (* (w0 ?r) (chop_duration)) (* (w2 ?r) (battery-chop_ingredients))))
      (when (< (- (battery-soc ?r) (battery-chop_ingredients)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-chop_ingredients)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action cook_meal
    :parameters (?r - robot ?m - meal ?l - location)
    :precondition (and
      (at ?r ?l)
      (cooking-station ?l)
      (meal_to_prepare ?m)
      (requires_cooking ?m)
      (ingredients_safe ?r ?m)
      (ingredients_washed ?r)
      (ingredients_chopped ?r)
      (workspace-clean ?r)
      (robot-hands-clean ?r)
      (not (cross-contamination-risk ?r))
      (not (meal_cooked ?r))
      (> (battery-soc ?r) (+ (battery-cook_meal) (nearest-charger-battery ?l)))
    )
    :effect (and
      (meal_cooked ?r)
      (ready_for_quality ?r)
      (increase (total_time) (cook_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-cook_meal))
      (increase (stage_cost) (+ (* (w0 ?r) (cook_duration)) (* (w2 ?r) (battery-cook_meal))))
      (when (< (- (battery-soc ?r) (battery-cook_meal)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-cook_meal)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action check_cooking_level
    :parameters (?r - robot ?l - location)
    :precondition (and
      (at ?r ?l)
      (quality-check-location ?l)
      (ready_for_quality ?r)
      (not (cooking_level_checked ?r))
      (> (battery-soc ?r) (+ (battery-check_cooking_level) (nearest-charger-battery ?l)))
    )
    :effect (and
      (cooking_level_checked ?r)
      (increase (total_time) (check_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-check_cooking_level))
      (increase (stage_cost) (+ (* (w0 ?r) (check_duration)) (* (w2 ?r) (battery-check_cooking_level))))
      (when (< (- (battery-soc ?r) (battery-check_cooking_level)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-check_cooking_level)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action check_palatability
    :parameters (?r - robot ?l - location)
    :precondition (and
      (at ?r ?l)
      (quality-check-location ?l)
      (ready_for_quality ?r)
      (cooking_level_checked ?r)
      (not (meal_palatable ?r))
      (> (battery-soc ?r) (+ (battery-check_palatability) (nearest-charger-battery ?l)))
    )
    :effect (and
      (meal_palatable ?r)
      (increase (total_time) (check_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-check_palatability))
      (increase (stage_cost) (+ (* (w0 ?r) (check_duration)) (* (w2 ?r) (battery-check_palatability))))
      (when (< (- (battery-soc ?r) (battery-check_palatability)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-check_palatability)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action assembla
    :parameters (?r - robot ?m - meal ?l - location)
    :precondition (and
      (at ?r ?l)
      (quality-check-location ?l)
      (meal_to_prepare ?m)
      (ingredients_safe ?r ?m)
      (ready_for_quality ?r)
      (cooking_level_checked ?r)
      (meal_palatable ?r)
      (not (meal_assembled ?r))
      (> (battery-soc ?r) (+ (battery-assembla) (nearest-charger-battery ?l)))
    )
    :effect (and
      (meal_assembled ?r)
      (increase (total_time) (assemble_duration))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-assembla))
      (increase (stage_cost) (+ (* (w0 ?r) (assemble_duration)) (* (w2 ?r) (battery-assembla))))
      (when (< (- (battery-soc ?r) (battery-assembla)) 0.15) (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (battery-assembla)) 0.25) (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

  (:action deliver_on_bedside_table_left
    :parameters (?r - robot ?l - location)
    :precondition (and
      (at ?r ?l)
      (patient-location ?l)
      (patient-left-location ?l)
      (ready_for_quality ?r)
      (meal_palatable ?r)
      (meal_assembled ?r)
      (can_be_deliverable ?r)
      (not (delivered ?r))
      (>= (battery-soc ?r) (battery-deliver_on_bedside_table))
    )
    :effect (and
      (increase (total_time) (deliver-time))
      (increase (discrete_steps) 1)
      (delivered ?r)
      (decrease (battery-soc ?r) (battery-deliver_on_bedside_table))
      (increase (stage_cost)
        (+ (* (w0 ?r) (deliver-time))
           (+ (* (w2 ?r) (battery-deliver_on_bedside_table))
              (* (w4 ?r) (approach-feature bedside_table_left)))))
    )
  )

  (:action deliver_on_bedside_table_right
    :parameters (?r - robot ?l - location)
    :precondition (and
      (at ?r ?l)
      (patient-location ?l)
      (patient-right-location ?l)
      (ready_for_quality ?r)
      (meal_palatable ?r)
      (meal_assembled ?r)
      (can_be_deliverable ?r)
      (not (delivered ?r))
      (>= (battery-soc ?r) (battery-deliver_on_bedside_table))
    )
    :effect (and
      (increase (total_time) (deliver-time))
      (increase (discrete_steps) 1)
      (delivered ?r)
      (decrease (battery-soc ?r) (battery-deliver_on_bedside_table))
      (increase (stage_cost)
        (+ (* (w0 ?r) (deliver-time))
           (+ (* (w2 ?r) (battery-deliver_on_bedside_table))
              (* (w4 ?r) (approach-feature bedside_table_right)))))
    )
  )

  (:action recharge
    :parameters (?r - robot ?l - location)
    :precondition (and
      (at ?r ?l)
      (charger-location ?l)
      (not (delivered ?r))
    )
    :effect (and
      (increase (total_time) (duration-recharge))
      (increase (discrete_steps) 1)
      (increase (stage_cost)
        (+ (* (w0 ?r) (duration-recharge))))
      (assign (battery-soc ?r) 1.0)
    )
  )
)

