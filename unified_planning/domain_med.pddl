    :precondition (and
      (at ?r ?l)
      (has-medication ?r)
      (carrying-medicine ?r ?m)
      (not (requested-medicine ?m))
      (unchecked-medication ?r)
      (not (delivered ?r))
      (not (medicine-recollect-required ?r))
      (not (supplement-recollect-required ?r))
      (> (battery-soc ?r)
         (+ (battery-check-medication)
            (+ (battery-collect-medication) (nearest-charger-battery ?l))))
    )
    :effect (and
      (increase (total_time) (duration-check-medication))
      (increase (discrete_steps) 1)
      (decrease (battery-soc ?r) (battery-check-medication))
      (not (unchecked-medication ?r))
      (not (correct-medication ?r))
      (medicine-recollect-required ?r)
      (increase (stage_cost)
        (+ (* (w0 ?r) (duration-check-medication))
           (* (w2 ?r) (battery-check-medication))))
    )
  )

  (:action check_supplement_correct
    :parameters (?r - robot ?l - location ?s - supplement)
    :precondition (and
      (at ?r ?l)
      (has-supplement ?r)
      (carrying-supplement ?r ?s)
      (requested-supplement ?s)
      (unchecked-supplement ?r)
      (not (delivered ?r))
      (not (medicine-recollect-required ?r))
      (not (supplement-recollect-required ?r))
      (> (battery-soc ?r) (+ (battery-check-supplement) (nearest-charger-battery ?l)))
