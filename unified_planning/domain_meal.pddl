    :precondition (and
      (at ?r ?from)
      (meal_to_prepare ?m)
      (patient-location ?to)
      (patient-right-location ?to)
      (not (= ?from ?to))
      (or (meal_cooked ?r) (not (requires_cooking ?m)))
      (meal_palatable ?r)
      (meal_assembled ?r)
      (not (delivered ?r))
      (>= (- (battery-soc ?r) (nav-battery ?from ?to))
          (+ (battery-deliver_on_bedside_table) (nearest-charger-battery ?to)))
    )
    :effect (and
      (increase (total_time) (nav-time ?from ?to))
      (increase (discrete_steps) 1)
      (not (at ?r ?from))
      (at ?r ?to)
      (can_be_deliverable ?r)
      (decrease (battery-soc ?r) (nav-battery ?from ?to))
      (increase (stage_cost)
