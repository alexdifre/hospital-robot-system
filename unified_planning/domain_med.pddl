  (:action put_down_medicine
    :parameters (?r - robot ?l - location ?m - medicine)
    :precondition (and
      (at ?r ?l)
      (has-medication ?r)
      (carrying-medicine ?r ?m)
      (not (unchecked-medication ?r))
      (not (correct-medication ?r))
      (> (battery-soc ?r) (+ (battery-put_down) (nearest-charger-battery ?l)))

    )
    :effect (and
      (not (has-medication ?r))
      (not (carrying-medicine ?r ?m))
      (medicine-recollect-required ?r)
      (increase (total_time) (duration-put_down))
      (increase (discrete_steps) 1)
