# ===================================================================
# Hospital Robot System .gitignore
# ===================================================================
# Excludes: Acados C build files, MPC solver artifacts, Python cache,
# MuJoCo logs, and other temporary files
# ===================================================================

# ===================================================================
# ACADOS BUILD FILES (CRITICAL - these caused issues before)
# ===================================================================
# C source and object files generated by Acados
*.c
*.o
*.so
*.dylib
*.dll

# Acados solver directories (auto-generated)
c_generated_code/
acados_ocp_nlp_*/
.acados_tmp/
.acados_runtime/

# JSON files (MPC solver configurations - auto-generated)
*.json

# Make build artifacts
Makefile
*.mk

# ===================================================================
# PYTHON
# ===================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# pyenv
.python-version

# ===================================================================
# MUJOCO
# ===================================================================
# MuJoCo logs and temporary files
mujoco_log.txt
*.mjb
*.mjcf~

# Video recordings (can be large)
*.mp4
*.avi
*.mov

# ===================================================================
# RESEARCH ARTIFACTS
# ===================================================================
# Experiment results
results/
experiments/
logs/
checkpoints/
*.log

# Data files (unless explicitly tracked)
data/
datasets/
*.pkl
*.pickle
*.npy
*.npz
*.h5
*.hdf5

# Model weights and trained models
models/
weights/
*.pt
*.pth
*.ckpt
*.model

# Visualization outputs
plots/
figures/
*.png
*.jpg
*.jpeg
*.svg
*.pdf

# But ALLOW documentation images and paper figure outputs
!docs/**/*.png
!docs/**/*.jpg
!ARCHITECTURE_DIAGRAM.png
!files/*.png
!files/*.pdf
!tests/figures/
!tests/figures/**/*.py

# ===================================================================
# IDE / EDITOR
# ===================================================================
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
.idea_modules/

# Vim
*.swp
*.swo
*~
.*.swp

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ===================================================================
# OS
# ===================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# ===================================================================
# LATEX (for paper writing)
# ===================================================================
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.toc
*.synctex.gz
*.log
*.pdf
# But ALLOW the actual paper PDFs if committed
!paper.pdf
!manuscript.pdf

# ===================================================================
# TEMPORARY FILES
# ===================================================================
tmp/
temp/
*.tmp
*.bak
*.swp
*.cache

# ===================================================================
# PROJECT-SPECIFIC
# ===================================================================
# Old working code (don't track in new structure)
old_code/
archive/
backup/

# Scratch/experimental scripts
scratch/

# Runtime logs
*.log
experiments_local/
test_*.py
debug_*.py

# Local configuration files (machine-specific)
local_config.py
.env
.env.local

# ===================================================================
# ALLOW THESE IMPORTANT FILES (override previous patterns)
# ===================================================================
# Core documentation
!README.md
!ARCHITECTURE.md
!SETUP.md
!TODO.md
!JANUARY_START_HERE.md
!SKILL.md

# Environment specification
!environment.yml
!requirements.txt

# Example/demo scripts
!demo_*.py
!example_*.py

# Test source files are real project code, even though scratch test_*.py files are ignored.
!tests/**/test_*.py
