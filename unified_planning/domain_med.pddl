  (:action collect_med_antibiotic
    :parameters (?r - robot ?l - location)
    :precondition (and
      (at ?r ?l)
      (pharmacy-location ?l)
      (not (has-medication ?r))
      (not (delivered ?r))
      (not (supplement-recollect-required ?r))
      (> (battery-soc ?r)
         (+ (battery-collect-medication)
            (+ (battery-check-medication)
               (+ (battery-put_down) (nearest-charger-battery ?l)))))
    )
    :effect (and
      (increase (total_time) (duration-collect-medication))
      (increase (discrete_steps) 1)
      (has-medication ?r)
      (carrying-medicine ?r med_antibiotic)
      (unchecked-medication ?r)
      (not (correct-medication ?r))
      (not (medicine-recollect-required ?r))
      (decrease (battery-soc ?r) (battery-collect-medication))
      (increase (stage_cost)
        (+ (* (w0 ?r) (duration-collect-medication))
           (* (w2 ?r) (battery-collect-medication))))
    )
  )

