(define (domain meal_preparation)
  (:requirements
    :strips
    :typing
    :equality
    :negative-preconditions
    :disjunctive-preconditions
    :universal-preconditions
    :conditional-effects
    :action-costs
    :numeric-fluents
  )

  (:types
    robot meal ingredient approach_target - object
    location delivery_target - approach_target
  )

  (:constants
    bedside_table_left bedside_table_right - delivery_target
    sandwich salad hot_meal - meal
  )

  (:predicates
    (at ?r - robot ?l - location)
    (connected ?from ?to - location)
    (meal_to_prepare ?m - meal)
    (meal_chosen ?r - robot)
    (requires_cooking ?m - meal)
    (cold_meal ?m - meal)

    (pantry-location ?l - location)
    (fridge-location ?l - location)
    (prep-station-location ?l - location)
    (cooking-station ?l - location)
    (quality-check-location ?l - location)
    (charger-location ?l - location)
    (main-charger ?l - location)
    (backup-charger ?l - location)
    (patient-location ?l - location)
    (patient-left-location ?l - location)
    (patient-right-location ?l - location)
    (required_ingredient ?m - meal ?i - ingredient)
    (ingredient_available ?l - location ?i - ingredient)
    (collected_ingredient ?r - robot ?i - ingredient)
    (missing_ingredient ?r - robot ?i - ingredient)
    (expired_ingredient ?r - robot ?i - ingredient)
    (wrong_ingredient ?r - robot ?i - ingredient)
    (allergen_present ?r - robot ?i - ingredient)
    (ingredients_checked ?r - robot)
    (ingredients_safe ?r - robot ?m - meal)

    (workspace-clean ?r - robot)
    (robot-hands-clean ?r - robot)
    (cross-contamination-risk ?r - robot)

    (ingredients_washed ?r - robot)
    (ingredients_chopped ?r - robot)
    (meal_cooked ?r - robot)
    (ready_for_quality ?r - robot)
    (cooking_level_checked ?r - robot)
    (meal_palatable ?r - robot)
    (meal_assembled ?r - robot)

    (can_be_deliverable ?r - robot)
    (delivered ?r - robot)
  )

  (:functions
    (stage_cost)
    (total_time)
    (discrete_steps)

    (loc-x ?l - location)
    (loc-y ?l - location)
    (nav-time ?from ?to - location)
    (nav-battery ?from ?to - location)
    (nearest-charger-battery ?l - location)
    (location-safety ?l - location)
    (approach-feature ?x - approach_target)
    (proximity-feature ?l - location)

    ; w0=time, w1=safety, w2=battery, w3=proximity, w4=approach.
    (w0 ?r - robot)
    (w1 ?r - robot)
    (w2 ?r - robot)
    (w3 ?r - robot)
    (w4 ?r - robot)

    (battery-soc ?r - robot)

    (collect_duration)
    (check_duration)
    (sanitize_duration)
    (wash_duration)
    (chop_duration)
    (cook_duration)
    (assemble_duration)
    (deliver-time)
    (duration-recharge)

    (battery-collect_ingredient)
    (battery-check_ingredients)
    (battery-sanitize_workspace)
    (battery-wash_ingredients)
    (battery-chop_ingredients)
    (battery-cook_meal)
    (battery-check_cooking_level)
    (battery-check_palatability)
    (battery-assembla)
    (battery-deliver_on_bedside_table)
  )

  (:action choose_sandwich
    :parameters (?r - robot ?m - meal)
    :precondition (and
      (not (meal_chosen ?r))
      (= ?m sandwich)
    )
    :effect (and
      (meal_chosen ?r)
      (meal_to_prepare ?m)
      (increase (discrete_steps) 1)
    )
  )

  (:action choose_salad
    :parameters (?r - robot ?m - meal)
    :precondition (and
      (not (meal_chosen ?r))
      (= ?m salad)
    )
    :effect (and
      (meal_chosen ?r)
      (meal_to_prepare ?m)
      (increase (discrete_steps) 1)
    )
  )

  (:action choose_hot_meal
    :parameters (?r - robot ?m - meal)
    :precondition (and
      (not (meal_chosen ?r))
      (= ?m hot_meal)
    )
    :effect (and
      (meal_chosen ?r)
      (meal_to_prepare ?m)
      (increase (discrete_steps) 1)
    )
  )

  (:action go_to_pantry
    :parameters (?r - robot ?from - location ?to - location)
    :precondition (and
      (at ?r ?from)
      (connected ?from ?to)
      (pantry-location ?to)
      (not (= ?from ?to))
      (>= (- (battery-soc ?r) (nav-battery ?from ?to)) (nearest-charger-battery ?to))
    )
    :effect (and
      (increase (total_time) (nav-time ?from ?to))
      (increase (discrete_steps) 1)
      (not (at ?r ?from))
      (at ?r ?to)
      (decrease (battery-soc ?r) (nav-battery ?from ?to))
      (increase (stage_cost)
        (+ (* (w0 ?r) (nav-time ?from ?to))
           (+ (* (w1 ?r) (location-safety ?to))
              (* (w2 ?r) (nav-battery ?from ?to)))))
      (when (< (- (battery-soc ?r) (nav-battery ?from ?to)) 0.15)
        (increase (stage_cost) (* (w2 ?r) 0.5)))
      (when (< (- (battery-soc ?r) (nav-battery ?from ?to)) 0.25)
        (increase (stage_cost) (* (w2 ?r) 0.2)))
    )
  )

